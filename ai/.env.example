# ─────────────────────────────────────────────────────────────────────────────
# VyaparMitra AI — .env.example
# Copy this file to .env and fill in your real values.
# ─────────────────────────────────────────────────────────────────────────────

# HuggingFace token (required to download Gemma from the Hub)
HF_TOKEN=hf_your_huggingface_token_here

# Gemma model identifier on HuggingFace Hub
GEMMA_MODEL_NAME=google/gemma-3-4b-it

# Sentence-Transformer model for embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Path where FAISS index will be stored/loaded from
FAISS_INDEX_PATH=./ai/embeddings/faiss.index

# Path to metadata pickle paired with the FAISS index
FAISS_META_PATH=./ai/embeddings/faiss_meta.pkl

# Default dataset path (CSV)
DATASET_PATH=./ai/datasets/sample_data.csv

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log file (leave blank to log to stdout only)
LOG_FILE=./ai/logs/vyaparmitra.log

# Max tokens for Gemma generation
MAX_NEW_TOKENS=512

# Top-k results to retrieve from FAISS
RETRIEVAL_TOP_K=5

# API prefix (for FastAPI router)
API_PREFIX=/api/v1
